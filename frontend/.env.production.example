# Frontend production environment variables

# Auth.js (required)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET=          # Generate with: npx auth secret

# Neon Auth (required)
# NEON_AUTH_BASE_URL: Find in Neon Console → Project → Branch → Auth → Configuration
# Format: https://ep-<id>.c-<region>.aws.neon.tech/<dbname>/auth
NEON_AUTH_BASE_URL=
# NEON_AUTH_COOKIE_SECRET: Generate with: openssl rand -base64 32 (must be 32+ chars)
NEON_AUTH_COOKIE_SECRET=

# BFF proxy → backend
BACKEND_URL=          # e.g. https://api.minis.dev
SERVICE_JWT_SECRET=   # Must match backend SERVICE_JWT_SECRET
